generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String
  avatarUrl   String?
  password    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  spaces           Space[]        @relation("SpaceCreator")
  pages            Page[]         @relation("PageCreator")
  comments         Comment[]
  pageViews        PageView[]
  pageVersions     PageVersion[]
  notifications    Notification[]
  spaceMemberships SpaceMember[]
  labels           Label[]        @relation("LabelCreator")
  attachments      Attachment[]
}

model Space {
  id          String   @id @default(cuid())
  name        String
  key         String   @unique
  description String?
  iconEmoji   String   @default("📄")
  isPrivate   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  creatorId String
  creator   User          @relation("SpaceCreator", fields: [creatorId], references: [id])
  pages     Page[]
  members   SpaceMember[]
  labels    Label[]
}

model SpaceMember {
  id       String   @id @default(cuid())
  role     String   @default("viewer")
  joinedAt DateTime @default(now())

  spaceId String
  space   Space  @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([spaceId, userId])
}

model Page {
  id          String    @id @default(cuid())
  title       String    @default("Untitled")
  content     String    @default("")
  contentText String    @default("")
  status      String    @default("draft")
  emoji       String    @default("📄")
  position    Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  publishedAt DateTime?

  spaceId   String
  space     Space  @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  creatorId String
  creator   User   @relation("PageCreator", fields: [creatorId], references: [id])
  parentId  String?
  parent    Page?  @relation("PageTree", fields: [parentId], references: [id])
  children  Page[] @relation("PageTree")

  comments    Comment[]
  versions    PageVersion[]
  views       PageView[]
  labels      PageLabel[]
  attachments Attachment[]

  @@index([spaceId])
  @@index([parentId])
  @@index([creatorId])
}

model PageVersion {
  id        String   @id @default(cuid())
  version   Int
  title     String
  content   String
  comment   String?
  createdAt DateTime @default(now())

  pageId   String
  page     Page   @relation(fields: [pageId], references: [id], onDelete: Cascade)
  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  @@index([pageId])
}

model Comment {
  id         String   @id @default(cuid())
  body       String
  isResolved Boolean  @default(false)
  anchorText String?
  anchorPos  Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  pageId   String
  page     Page      @relation(fields: [pageId], references: [id], onDelete: Cascade)
  authorId String
  author   User      @relation(fields: [authorId], references: [id])
  parentId String?
  parent   Comment?  @relation("CommentThread", fields: [parentId], references: [id])
  replies  Comment[] @relation("CommentThread")

  @@index([pageId])
}

model PageView {
  id       String   @id @default(cuid())
  viewedAt DateTime @default(now())

  pageId String
  page   Page   @relation(fields: [pageId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([pageId])
  @@index([userId])
}

model Label {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("#6b7280")
  spaceId   String?
  createdAt DateTime @default(now())

  creatorId String
  creator   User        @relation("LabelCreator", fields: [creatorId], references: [id])
  space     Space?      @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  pages     PageLabel[]

  @@unique([name, spaceId])
}

model PageLabel {
  pageId  String
  page    Page  @relation(fields: [pageId], references: [id], onDelete: Cascade)
  labelId String
  label   Label @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([pageId, labelId])
}

model Notification {
  id        String   @id @default(cuid())
  type      String
  title     String
  body      String
  isRead    Boolean  @default(false)
  metadata  Json?
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
}

model Attachment {
  id         String   @id @default(cuid())
  filename   String
  storedName String
  mimeType   String
  size       Int
  createdAt  DateTime @default(now())

  pageId     String
  page       Page   @relation(fields: [pageId], references: [id], onDelete: Cascade)
  uploaderId String
  uploader   User   @relation(fields: [uploaderId], references: [id])

  @@index([pageId])
}
